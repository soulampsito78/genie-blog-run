# Worker image: runs the orchestrator (run_orchestrator.py) only.
# Same app and dependencies as the API; only the default command is different.
# Email-only first rollout: no Playwright browser install.
FROM python:3.11

WORKDIR /app

COPY requirements.txt .
RUN pip install -r requirements.txt

COPY . .

# Mode is set via GENIE_MODE env when you create the Cloud Run Job.
CMD ["python", "run_orchestrator.py"]
